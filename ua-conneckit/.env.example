# Particle Network Configuration
NEXT_PUBLIC_PROJECT_ID=your_project_id
NEXT_PUBLIC_CLIENT_KEY=your_client_key
NEXT_PUBLIC_APP_ID=your_app_id

# Privy (match example: https://github.com/Particle-Network/universal-accounts-7702)
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id
NEXT_PUBLIC_PRIVY_CLIENT_ID=your_privy_client_id

# Clicker API Proxy URL (Cloudflare worker)
# After deploying workers/clicker-proxy/, set this to your worker URL
# Example: https://clicker-proxy.your-subdomain.workers.dev
# NEXT_PUBLIC_CLICKER_PROXY_URL=https://clicker-proxy.your-subdomain.workers.dev
